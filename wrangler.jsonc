{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pfs-website",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "/api/*",
      "zone_name": "projectfutureself.com"
    }
  ]
}

